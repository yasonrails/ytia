<!-- ══ SECTEURS ═══════════════════════════════════════════════ -->
<section class="secteurs" id="secteurs">
  <div class="z">
    <div class="secteurs-hd" data-r>
      <div class="eyebrow">Secteurs d'intervention</div>
      <h2 class="sh">Une connaissance sectorielle<br><span class="grad">qui élève la qualité</span> des livrables</h2>
    </div>
    <div class="secteurs-grid">
      <% sectors = [
        { title: "État & Collectivités", description: "Dématérialisation des parcours, assistance à la décision réglementaire et automatisation des procédures administratives." },
        { title: "Défense & Sécurité", description: "Traitement de corpus sensibles, classification avancée et dispositifs de veille en environnements isolés et contrôlés.", delay: 1 },
        { title: "Santé & Médico-social", description: "Aide à la décision clinique, gestion documentaire HDS et automatisation conforme aux exigences RGPD et PGSSI-S.", delay: 2 },
        { title: "Finance & Assurance", description: "Détection d'anomalies, scoring décisionnel, synthèse réglementaire et automatisation des contrôles d'audit.", delay: 3 },
        { title: "Industrie & Énergie", description: "Maintenance prédictive, optimisation des flux opérationnels, supervision intelligente et jumeaux numériques." },
        { title: "Éducation & Recherche", description: "Dispositifs pédagogiques adaptatifs, traitement de corpus académiques et veille scientifique automatisée.", delay: 1 },
        { title: "Juridique & Conformité", description: "Analyse contractuelle, recherche jurisprudentielle, génération documentaire et contrôle de conformité.", delay: 2 },
        { title: "Commerce & E-commerce", description: "Personnalisation à grande échelle, prévision des stocks et automatisation des opérations de service client.", delay: 3 }
      ] %>

      <% sectors.each do |sector| %>
        <%= render "pages/home/sector_card", sector: sector %>
      <% end %>
    </div>
  </div>
</section>

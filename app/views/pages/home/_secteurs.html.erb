<!-- ══ SECTEURS ═══════════════════════════════════════════════ -->
<section class="secteurs" id="secteurs">
  <div class="z">
    <div class="secteurs-hd" data-r>
      <div class="eyebrow">Secteurs d'intervention</div>
      <h2 class="sh">Une connaissance sectorielle<br><span class="grad">qui change la qualité</span> des livrables</h2>
    </div>
    <div class="secteurs-grid">
      <% sectors = [
        { title: "État & Collectivités", description: "Dématérialisation, aide à la décision réglementaire, automatisation des procédures administratives." },
        { title: "Défense & Sécurité", description: "Analyse de corpus sensibles, classification, systèmes de veille en environnement isolé et contrôlé.", delay: 1 },
        { title: "Santé & Médico-social", description: "Aide à la décision clinique, gestion documentaire HDS, automatisation conforme RGPD et PGSSI-S.", delay: 2 },
        { title: "Finance & Assurance", description: "Détection d'anomalies, scoring décisionnel, synthèse réglementaire et audit automatisé.", delay: 3 },
        { title: "Industrie & Énergie", description: "Maintenance prédictive, optimisation de flux, supervision intelligente et jumeaux numériques." },
        { title: "Éducation & Recherche", description: "Dispositifs adaptatifs, traitement de corpus académiques, veille scientifique automatisée.", delay: 1 },
        { title: "Juridique & Compliance", description: "Analyse contractuelle, recherche jurisprudentielle, génération et contrôle de documents.", delay: 2 },
        { title: "Retail & E-commerce", description: "Personnalisation à grande échelle, prévision de stocks, automatisation du service client.", delay: 3 }
      ] %>

      <% sectors.each do |sector| %>
        <%= render "pages/home/sector_card", sector: sector %>
      <% end %>
    </div>
  </div>
</section>

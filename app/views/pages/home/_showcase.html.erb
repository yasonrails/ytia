<!-- ══ SHOWCASE / PORTFOLIO ══════════════════════════════════ -->
<section class="showcase" id="portfolio">
  <div class="z">
    <div class="showcase-hd" data-r>
      <div class="eyebrow">Réalisations</div>
      <h2 class="sh">Ce que nous avons <span class="grad">mis en production</span></h2>
      <p class="sd">Trois missions conduites en environnement réel, avec des objectifs mesurables et des systèmes aujourd'hui exploités en production.</p>
    </div>

    <div class="showcase-grid">
      <% cards = [
        {
          image: "https://images.unsplash.com/photo-1568667256549-094345857637?w=1000&q=80&fit=crop",
          alt: "Portail appels d'offres IA",
          category: "Secteur public · LLM / RAG",
          name: "Portail intelligent de gestion des appels d'offres publics",
          kpi: "-42% de temps de qualification dossier",
          delay: nil
        },
        {
          image: "https://images.unsplash.com/photo-1485827404703-89b55fcc595e?w=700&q=80&fit=crop",
          alt: "Robot et maintenance prédictive IoT",
          category: "Industrie · MLOps",
          name: "Orchestrateur de maintenance prédictive IoT multi-sites",
          kpi: "+31% de disponibilité machine sur 6 mois",
          delay: 1
        },
        {
          image: "https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=700&q=80&fit=crop",
          alt: "IA générative analyse contractuelle",
          category: "Juridique · IA générative",
          name: "Chaîne d'analyse contractuelle avec synthèses et scoring de clauses",
          kpi: "95% de conformité de pré-contrôle documentaire",
          delay: 2
        }
      ] %>

      <% cards.each do |card| %>
        <%= render "pages/home/showcase_card", card: card %>
      <% end %>
    </div>
  </div>
</section>

  <!-- ═══ PRÉSENTATION ════════════════════════════════════════ -->
  <section class="s" id="entreprise">
    <div class="z">
      <div class="intro-grid">
        <div data-r>
          <span class="lbl">Notre entreprise</span>
          <h2 class="sh sh-l">À la croisée de l'ingénierie,<br>du cloud et de l'<em>IA.</em></h2>
          <p class="lg" style="margin-bottom:20px">
            Spécialisés dans la conception et le développement de solutions logicielles
            avancées, nous aidons les organisations publiques et privées à automatiser
            leurs processus, exploiter leurs données et construire des systèmes numériques
            robustes, évolutifs et souverains.
          </p>
          <p class="md">
            Nous combinons expertise full-stack, DevOps, machine learning et architecture
            cloud native pour proposer des plateformes modernes, sécurisées et adaptées
            aux enjeux actuels.
          </p>
        </div>
        <div data-r data-d="1">
          <div class="pillars">
            <div class="pillar"><span class="pn">01</span><div><h4>Ingénierie logicielle</h4><p>Full-stack, API, architectures distribuées</p></div></div>
            <div class="pillar"><span class="pn">02</span><div><h4>Architecture cloud & Kubernetes</h4><p>Cloud native, multi-cloud, IaC</p></div></div>
            <div class="pillar"><span class="pn">03</span><div><h4>Orchestration IA</h4><p>Multi-providers LLM, MLOps, RAG, pipelines</p></div></div>
            <div class="pillar"><span class="pn">04</span><div><h4>Automatisation & analyse</h4><p>Processus métiers, documentaire, décisionnel</p></div></div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══ VISION ══════════════════════════════════════════════ -->
  <section class="s s-g" id="vision">
    <div class="z">
      <span class="lbl" data-r>Vision</span>
      <h2 class="sh" data-r>Des systèmes pensés pour <em>durer et évoluer.</em></h2>
      <div class="vgrid">
        <div class="vc" data-r><span class="vc-num">1</span><div class="vc-bar"></div><h3>Autonomes</h3><p>Opèrent sans intervention constante, avec résilience et auto-correction automatiques.</p></div>
        <div class="vc" data-r data-d="1"><span class="vc-num">2</span><div class="vc-bar"></div><h3>Scalables par conception</h3><p>Architectures extensibles horizontalement, prêtes pour la croissance sans refonte.</p></div>
        <div class="vc" data-r data-d="2"><span class="vc-num">3</span><div class="vc-bar"></div><h3>Résilients</h3><p>Haute disponibilité, tolérance aux pannes, continuité de service assurée.</p></div>
        <div class="vc" data-r><span class="vc-num">4</span><div class="vc-bar"></div><h3>Sécurisés</h3><p>Zero-trust, chiffrement, conformité RGPD & NIS2 — intégrés dès la conception.</p></div>
        <div class="vc" data-r data-d="1"><span class="vc-num">5</span><div class="vc-bar"></div><h3>Interopérables</h3><p>API-first, standards ouverts, intégration native avec les SI existants.</p></div>
        <div class="vc" data-r data-d="2"><span class="vc-num">6</span><div class="vc-bar"></div><h3>Multi-cloud & multi-vendor</h3><p>Indépendance totale — AWS, GCP, Azure, on-premise ou infrastructure privée souveraine.</p></div>
      </div>
    </div>
  </section>


  <!-- ═══ EXPERTISE ════════════════════════════════════════════ -->
  <section class="s" id="expertise">
    <div class="z">
      <span class="lbl" data-r>Expertise principale</span>
      <h2 class="sh" data-r>Ce que nous <em>construisons.</em></h2>

      <!-- 01 -->
      <div class="xb xb-rev" data-r>
        <div class="xt">
          <div class="xt-num" aria-hidden="true">01</div>
          <span class="xt-tag">Plateformes IA</span>
          <h3>IA multi-providers</h3>
          <p>Nous concevons des architectures orchestrant plusieurs fournisseurs de modèles — LLM, spécialisés, open source ou propriétaires. Ces systèmes garantissent portabilité, résilience et optimisation des coûts tout en préservant la souveraineté technologique.</p>
          <div class="tags"><span>Portabilité</span><span>Résilience</span><span>Coût optimisé</span><span>Souveraineté</span><span>Évolutivité</span></div>
        </div>
        <div class="xv xv-blue" data-xv>
          <div class="hub">
            <div class="hub-c">Orchestrateur YTIA</div>
            <div class="hub-g">
              <div class="hub-n">Mistral AI</div>
              <div class="hub-n">OpenAI GPT</div>
              <div class="hub-n">LLaMA 3</div>
              <div class="hub-n">Custom</div>
            </div>
          </div>
        </div>
      </div>

      <!-- 02 -->
      <div class="xb" data-r>
        <div class="xt">
          <div class="xt-num" aria-hidden="true">02</div>
          <span class="xt-tag">MLOps & Cloud</span>
          <h3>Orchestration et MLOps</h3>
          <p>Plateformes gérant l'ensemble du cycle de vie des modèles : déploiement, monitoring, évaluation, versioning, isolation des workloads et optimisation des ressources. Conception cloud native et Kubernetes.</p>
          <div class="tags"><span>Déploiement</span><span>Monitoring</span><span>Évaluation</span><span>Versioning</span><span>Kubernetes</span></div>
        </div>
        <div class="xv xv-indigo" data-xv>
          <div class="cyc">
            <div class="crow"><div class="cn">Train</div><div class="ca">→</div><div class="cn">Evaluate</div><div class="ca">→</div><div class="cn">Deploy</div></div>
            <div class="crow" style="opacity:.65"><div class="cn">Monitor</div><div class="ca">←</div><div class="cn">Serve</div><div class="ca">←</div><div class="cn">Version</div></div>
          </div>
        </div>
      </div>

      <!-- 03 -->
      <div class="xb xb-rev" data-r>
        <div class="xt">
          <div class="xt-num" aria-hidden="true">03</div>
          <span class="xt-tag">Analyse documentaire</span>
          <h3>Automatisation documentaire et analyse intelligente</h3>
          <p>Systèmes analysant automatiquement des documents complexes — DCE, appels d'offres, cahiers des charges, contrats. Extraction, conformité, aide à la décision, recherche intelligente et synthèse automatisée.</p>
          <div class="tags"><span>DCE & AO</span><span>Extraction</span><span>Conformité</span><span>Recherche sémantique</span><span>Synthèse</span></div>
        </div>
        <div class="xv xv-teal" data-xv>
          <div class="docf">
            <div class="dcol"><div class="df">DCE.pdf</div><div class="df">Contrat.docx</div><div class="df">CdC.pdf</div></div>
            <div class="da">→</div>
            <div class="dcol"><div class="do">Extraction</div><div class="do">Conformité</div><div class="do">Décision</div></div>
          </div>
        </div>
      </div>

      <!-- 04 -->
      <div class="xb" data-r>
        <div class="xt">
          <div class="xt-num" aria-hidden="true">04</div>
          <span class="xt-tag">Software</span>
          <h3>Logiciels métier sur mesure</h3>
          <p>De la conception produit jusqu'à la mise en production — SaaS, applications métiers, plateformes collaboratives, outils de pilotage, interfaces décisionnelles. Stack complète maîtrisée en interne.</p>
          <div class="tags"><span>SaaS</span><span>Apps métiers</span><span>Collaboratif</span><span>Pilotage</span><span>Décisionnel</span></div>
        </div>
        <div class="xv xv-slate" data-xv>
          <div class="sbs">
            <div class="sb"><span class="sb-l">UI / UX</span><div class="sb-t"><div class="sb-f"></div></div></div>
            <div class="sb"><span class="sb-l">API</span><div class="sb-t"><div class="sb-f"></div></div></div>
            <div class="sb"><span class="sb-l">Backend</span><div class="sb-t"><div class="sb-f"></div></div></div>
            <div class="sb"><span class="sb-l">Infra</span><div class="sb-t"><div class="sb-f"></div></div></div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══ MÉTHODOLOGIE ════════════════════════════════════════ -->
  <section class="s s-g" id="methodologie">
    <div class="z">
      <span class="lbl" data-r>Méthodologie</span>
      <h2 class="sh" data-r>Architecture first. <em>Delivery always.</em></h2>
      <div class="mgrid">
        <div class="mc" data-r><span class="mc-n">01</span><h4>Architecture first</h4><p>Vision architecturale claire avant la première ligne de code — chaque décision est justifiée et documentée.</p></div>
        <div class="mc" data-r data-d="1"><span class="mc-n">02</span><h4>Infrastructure as code</h4><p>Terraform, Kubernetes, Helm — chaque composant infra est versionné, auditable et reproductible.</p></div>
        <div class="mc" data-r data-d="2"><span class="mc-n">03</span><h4>Sécurité by design</h4><p>Zero-trust, chiffrement, RBAC — la sécurité est intégrée dès la conception, jamais après.</p></div>
        <div class="mc" data-r><span class="mc-n">04</span><h4>Observabilité & fiabilité</h4><p>Logs structurés, traces distribuées, métriques — visibilité complète sur chaque composant.</p></div>
        <div class="mc" data-r data-d="1"><span class="mc-n">05</span><h4>Design produit</h4><p>Interfaces pensées pour l'utilisateur final — UX, accessibilité et performance perçue.</p></div>
        <div class="mc" data-r data-d="2"><span class="mc-n">06</span><h4>Déploiement continu</h4><p>CI/CD robuste, tests automatisés, rollback instantané — delivery rapide sans compromis.</p></div>
      </div>
    </div>
  </section>



<section class="hero">
  <div class="hero__inner container">
    <div class="hero__badge">Intelligence Artificielle · On-Premise · Sur Mesure</div>

    <h1 class="hero__title">
      Vos processus,<br>
      <span class="hero__title--accent">transformés par lIA.</span>
    </h1>

    <p class="hero__sub">
      YTIA déploie des agents IA, automatise vos métiers et construit vos
      plateformes logicielles — en local, souverain, sans dépendance cloud.
    </p>

    <div class="hero__actions">
      <%= link_to "Démarrer un projet", "#contact", class: "btn btn--primary" %>
      <%= link_to "Voir l'approche", "#approche", class: "btn btn--ghost" %>
    </div>
  </div>

  <div class="hero__grid" aria-hidden="true"></div>
  <div class="hero__glow" aria-hidden="true"></div>
</section>


<section class="services" id="services">
  <div class="container">
    <div class="section-label">Expertise</div>

    <div class="services__grid">

      <article class="service-card" data-reveal>
        <div class="service-card__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3 class="service-card__title">IA & Agents Intelligents</h3>
        <p class="service-card__desc">
          LLM open-source fine-tunés sur vos données, agents métiers autonomes,
          pipelines RAG, automatisation documentaire. Déployé en on-premise —
          vos données ne quittent pas votre infrastructure.
        </p>
        <ul class="service-card__list">
          <li>LLaMA · Mistral · Phi fine-tunés</li>
          <li>Agents IA sur workflows réels</li>
          <li>RAG sur base documentaire</li>
          <li>On-premise · Air-gapped</li>
        </ul>
      </article>

      <article class="service-card" data-reveal>
        <div class="service-card__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <h3 class="service-card__title">Architecture & Développement</h3>
        <p class="service-card__desc">
          Applications Rails 8 natif, API robustes, modernisation de systèmes
          legacy, architectures scalables et intégrations multi-systèmes.
          Code livré propre, testé, documenté.
        </p>
        <ul class="service-card__list">
          <li>Ruby on Rails 8 · Hotwire natif</li>
          <li>API REST / GraphQL</li>
          <li>Migration legacy · Microservices</li>
          <li>CI/CD · Tests · DevOps</li>
        </ul>
      </article>

      <article class="service-card" data-reveal>
        <div class="service-card__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3 class="service-card__title">Transformation & Automatisation</h3>
        <p class="service-card__desc">
          Automatisation des processus métiers répétitifs, orchestration de
          workflows, tableaux de bord décisionnels et accompagnement des
          équipes dans la durée.
        </p>
        <ul class="service-card__list">
          <li>RPA · Automatisation métier</li>
          <li>Orchestration · Monitoring</li>
          <li>Dashboards analytiques</li>
          <li>Accompagnement long terme</li>
        </ul>
      </article>

    </div>
  </div>
</section>



<section class="approche" id="approche">
  <div class="container">
    <div class="section-label">Méthode</div>
    <h2 class="section-title">Simple. Rigoureux. Livré.</h2>

    <div class="steps">
      <div class="step" data-reveal>
        <div class="step__num">01</div>
        <div class="step__body">
          <h4>Cadrage & Analyse</h4>
          <p>On part de vos vrais enjeux : processus, contraintes, données existantes.
          Pas de template générique — un diagnostic honnête en 1 à 2 semaines.</p>
        </div>
      </div>
      <div class="step__connector" aria-hidden="true"></div>
      <div class="step" data-reveal>
        <div class="step__num">02</div>
        <div class="step__body">
          <h4>Conception & Développement</h4>
          <p>Architecture propre, sprints courts, démos régulières. Le code est propre, testé et versionné.</p>
        </div>
      </div>
      <div class="step__connector" aria-hidden="true"></div>
      <div class="step" data-reveal>
        <div class="step__num">03</div>
        <div class="step__body">
          <h4>Déploiement & Autonomie</h4>
          <p>Mise en production maîtrisée, documentation complète, transfert de
          compétences. Vous êtes autonomes — ou accompagnés si vous le souhaitez.</p>
        </div>
      </div>
    </div>
  </div>
</section>



<section class="secteurs" id="secteurs">
  <div class="container">
    <div class="secteurs__inner">

      <div class="secteurs__left" data-reveal>
        <div class="section-label">Secteurs & Marchés Publics</div>
        <h2 class="section-title">Public · Privé ·<br>Secteurs sensibles.</h2>
        <p class="secteurs__text">
          YTIA intervient auprès des collectivités, administrations, PME industrielles
          et ETI. Structure capable de répondre aux marchés publics numériques :
          MAPA, accords-cadres, documentation technique complète, conformité RGPD.
        </p>
        <div class="secteurs__badges">
          <span class="badge">Collectivités</span>
          <span class="badge">Santé</span>
          <span class="badge">Industrie</span>
          <span class="badge">Finance</span>
          <span class="badge">Agriculture</span>
          <span class="badge">Éducation</span>
        </div>
      </div>

      <div class="secteurs__right" data-reveal>
        <div class="marches-card">
          <div class="marches-card__header">Marchés Publics</div>
          <ul class="marches-list">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20,6 9,17 4,12"/></svg>
              Réponse aux appels doffres ouverts & MAPA
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20,6 9,17 4,12"/></svg>
              Mémoire technique structuré
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20,6 9,17 4,12"/></svg>
              Conformité RGPD · NIS2
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20,6 9,17 4,12"/></svg>
              Documentation & gouvernance complètes
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20,6 9,17 4,12"/></svg>
              Hébergement France · Données souveraines
            </li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>


<section class="contact" id="contact">
  <div class="container">
    <div class="contact__inner">
      <div class="contact__left" data-reveal>
        <div class="section-label">Contact</div>
        <h2 class="section-title">Un projet en tête ?<br>Parlons-en.</h2>
        <p class="contact__sub">
          Premier échange confidentiel, sans engagement.
          Réponse sous 24h ouvrées.
        </p>
        <div class="contact__meta">
          <div class="contact__meta-item">
            <span class="contact__meta-key">Email</span>
            <a href="mailto:contact@ytia.fr" class="contact__meta-val">contact@ytia.fr</a>
          </div>
          <div class="contact__meta-item">
            <span class="contact__meta-key">Format</span>
            <span class="contact__meta-val">Visio ou présentiel</span>
          </div>
        </div>
      </div>

      <div class="contact__form-wrap" data-reveal>
        <%= form_with url: "#", method: :post, class: "contact-form" do |f| %>
          <div class="field">
            <%= f.label :name, "Nom & Organisation" %>
            <%= f.text_field :name, placeholder: "Jean Dupont · Mairie de Lyon" %>
          </div>
          <div class="field">
            <%= f.label :email, "Email professionnel" %>
            <%= f.email_field :email, placeholder: "j.dupont@organisation.fr" %>
          </div>
          <div class="field">
            <%= f.label :message, "Votre projet" %>
            <%= f.text_area :message, rows: 4, placeholder: "Décrivez brièvement votre besoin…" %>
          </div>
          <%= f.submit "Envoyer →", class: "btn btn--primary btn--full" %>
        <% end %>
      </div>
    </div>
  </div>
</section>



<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">YTIA</div>
    <div class="footer__copy">© <%= Time.current.year %> YTIA · Intelligence Artificielle sur Mesure</div>
    <nav class="footer__links" aria-label="Footer">
      <%= link_to "Mentions légales", "#" %>
      <%= link_to "Confidentialité", "#" %>
    </nav>
  </div>
</footer>


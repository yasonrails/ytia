    <div class="z">
      <span class="lbl" data-r>Clients & secteurs</span>
      <h2 class="sh" data-r>Public · Privé · <em>Sensibles.</em></h2>
      <div class="sgrid">
        <div class="sc" data-r><div class="sc-b"></div><h4>Entreprises technologiques</h4><p>Scale-ups, éditeurs logiciels, plateformes SaaS</p></div>
        <div class="sc" data-r data-d="1"><div class="sc-b"></div><h4>PME & ETI</h4><p>Transformation numérique, modernisation SI</p></div>
        <div class="sc" data-r data-d="2"><div class="sc-b"></div><h4>Secteur public</h4><p>Administrations, ministères, opérateurs d État</p></div>
        <div class="sc" data-r data-d="3"><div class="sc-b"></div><h4>Collectivités</h4><p>Régions, métropoles, communes, EPCI</p></div>
        <div class="sc" data-r><div class="sc-b"></div><h4>Industrie</h4><p>Manufacturing, maintenance prédictive, IoT</p></div>
        <div class="sc" data-r data-d="1"><div class="sc-b"></div><h4>Défense & souveraineté</h4><p>Systèmes sécurisés, air-gapped, conformité</p></div>
        <div class="sc" data-r data-d="2"><div class="sc-b"></div><h4>Conseil & services</h4><p>ESN, cabinets, opérateurs marchés publics</p></div>
      </div>
    </div>
  </section>


  <!-- ═══ DIFFÉRENCIATEURS ════════════════════════════════════ -->
  <section class="s s-g" id="differenciateurs">
    <div class="z">
      <span class="lbl" data-r>Pourquoi nous</span>
      <h2 class="sh" data-r>Ce qui nous <em>différencie.</em></h2>
      <div class="dgrid">
        <div class="di" data-r><div class="di-n">01</div><div><h4>Vision plateforme, pas simple intégration</h4><p>Systèmes complets et cohérents — pas des assemblages d'outils tiers sans vision globale.</p></div></div>
        <div class="di" data-r data-d="1"><div class="di-n">02</div><div><h4>Expertise combinée IA + cloud + software</h4><p>Une équipe couvrant l'ensemble de la stack — de l'algorithme à l'infrastructure.</p></div></div>
        <div class="di" data-r><div class="di-n">03</div><div><h4>Indépendance vis-à-vis des fournisseurs</h4><p>Architectures vendor-agnostic, open source first, portabilité garantie.</p></div></div>
        <div class="di" data-r data-d="1"><div class="di-n">04</div><div><h4>Forte capacité de prototypage et delivery</h4><p>De l'idée à la mise en production en semaines, avec des métriques mesurables.</p></div></div>
        <div class="di" data-r><div class="di-n">05</div><div><h4>Culture produit et ingénierie</h4><p>Code propre, tests, documentation — nous construisons pour le long terme.</p></div></div>
        <div class="di" data-r data-d="1"><div class="di-n">06</div><div><h4>Autonomie complète sur la stack</h4><p>Aucune dépendance non maîtrisée — chaque brique est comprise et contrôlée.</p></div></div>
      </div>
    </div>
  </section>



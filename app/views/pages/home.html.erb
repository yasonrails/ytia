    <div class="z">
      <div class="cgrid">
        <div data-r>
          <span class="lbl">Contact</span>
          <h2 class="sh sh-l">Démarrons<br><em>votre projet.</em></h2>
          <p class="lg" style="margin-bottom:32px">Système à construire, processus à automatiser ou infrastructure à moderniser — échangeons sans engagement.</p>
          <div class="ctas">
            <a href="mailto:contact@ytia.fr" class="btn btn-dk">contact@ytia.fr</a>
            <span style="font-family:var(--mono);font-size:.68rem;color:var(--t3)">Réponse sous 24h</span>
          </div>
        </div>
        <div data-r data-d="1">
          <div class="cform">
            <div class="field"><label>Nom & Organisation</label><input type="text" placeholder="Jean Dupont · Mairie de Lyon"></div>
            <div class="field"><label>Email professionnel</label><input type="email" placeholder="j.dupont@organisation.fr"></div>
            <div class="field">
              <label>Type de projet</label>
              <select>
                <option value="">Sélectionner…</option>
                <option>Plateforme IA multi-providers</option>
                <option>MLOps & infrastructure cloud</option>
                <option>Analyse documentaire intelligente</option>
                <option>Logiciel métier sur mesure</option>
                <option>Conseil & architecture</option>
              </select>
            </div>
            <div class="field"><label>Votre projet</label><textarea placeholder="Décrivez brièvement votre besoin…"></textarea></div>
            <button class="fsub">Envoyer le message →</button>
          </div>
        </div>
      </div>
    </div>
  </section>


